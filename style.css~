
body
{
margin:0;
font-family:Times New Roman;

background-image:url("bgbg.jpeg");
background-size:cover;
background-repeat:no-repeat;
background-position:center;

text-align:center;
}


.header
{
background:lightblue;
color:black;
padding:40px;
}


.searchbox
{
margin:40px;
}



input
{
width:400px;
padding:12px;
font-size:16px;
border-radius:6px;
border:1px solid gray;
}


button
{
padding:12px 25px;

background:linear-gradient(#3d7cc3,#1f5fa5);

color:white;

border:none;

border-radius:6px;

cursor:pointer;

font-size:16px;
}




.card
{
display:inline-block;

padding:15px 30px;

margin:10px;

background:white;

border-radius:8px;

box-shadow:0px 3px 8px gray;

font-size:18px;
}



.about
{
margin:40px auto;

width:80%;

background:rgba(255,255,255,0.85);

padding:20px;

border-radius:10px;
}



.footer
{
background:lightblue;

color:black;

padding:15px;

margin-top:40px;
}